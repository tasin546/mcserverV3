#!/bin/bash
export THIS_DIR=$PWD

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()    { echo -e "${CYAN}> $1${NC}"; }
success() { echo -e "${GREEN}> $1${NC}"; }
warn()    { echo -e "${YELLOW}> $1${NC}"; }
error()   { echo -e "${RED}> ERROR: $1${NC}"; }

RETRY_COUNT=0
MAX_RETRIES=3

install_server() {
  local choice=$1

  # Default to Vanilla if no input given
  if [[ -z "$choice" ]]; then
    choice=1
  fi

  case "$choice" in
    1)
      info "Installing Vanilla..."
      cd JavaInstallScripts && chmod +x VanillaInstall && ./VanillaInstall
      local err=$?
      cd "$THIS_DIR"
      if [ $err -ne 0 ]; then
        RETRY_COUNT=$((RETRY_COUNT + 1))
        if [ "$RETRY_COUNT" -ge "$MAX_RETRIES" ]; then
          error "Vanilla installation failed after $MAX_RETRIES attempts. Please check your internet and try again."
          exit 1
        fi
        error "Vanilla installation failed. Retrying (attempt $((RETRY_COUNT + 1))/$MAX_RETRIES)..."
        install_server "$choice"
      fi
      ;;
    2)
      info "Installing Paper..."
      cd JavaInstallScripts && chmod +x PaperInstall && ./PaperInstall
      cd "$THIS_DIR"
      ;;
    3)
      info "Installing Forge..."
      cd JavaInstallScripts && chmod +x ForgeInstall && ./ForgeInstall
      cd "$THIS_DIR"
      ;;
    4)
      info "Installing Sponge..."
      cd JavaInstallScripts && chmod +x SpongeInstall && ./SpongeInstall
      cd "$THIS_DIR"
      ;;
    5)
      info "Installing Fabric..."
      cd JavaInstallScripts && chmod +x FabricInstall && ./FabricInstall
      cd "$THIS_DIR"
      ;;
    6)
      info "Installing Spigot (compiling from source — this takes a while)..."
      cd JavaInstallScripts && chmod +x SpigotInstall && ./SpigotInstall
      cd "$THIS_DIR"
      ;;
    7)
      info "Installing BungeeCord (latest)..."
      cd JavaInstallScripts && chmod +x BungeecordInstall && ./BungeecordInstall
      cd "$THIS_DIR"
      ;;
    *)
      error "Invalid choice '$choice'. Please try again."
      return 1
      ;;
  esac
}

# =============================================
# Install required system dependencies
# =============================================
info "Installing system dependencies..."
sudo apt install -y -qq screen 2>/dev/null

success "Dependencies installed!"

mkdir -p server

echo ""
echo "-- Pick the server type you want to use: --"
echo "  [1] Vanilla    (Official Mojang server)"
echo "  [2] Paper      (High-performance, plugin support)"
echo "  [3] Forge      (Mod support)"
echo "  [4] Sponge     (Plugin/Mod hybrid)"
echo "  [5] Fabric     (Lightweight mod support)"
echo "  [6] Spigot     (Plugin support, compiled from source)"
echo "  [7] BungeeCord (Proxy for multi-server networks)"
echo ""

while true; do
  read -rp "Enter choice [1-7]: " choiceForServer
  install_server "$choiceForServer"
  if [ $? -eq 0 ]; then
    break
  fi
done

# =============================================
# Install Playit.gg
# =============================================
info "Installing Playit.gg..."
curl -SsL https://playit-cloud.github.io/ppa/key.gpg | gpg --dearmor | sudo tee /etc/apt/trusted.gpg.d/playit.gpg > /dev/null
echo "deb [signed-by=/etc/apt/trusted.gpg.d/playit.gpg] https://playit-cloud.github.io/ppa/data ./" | sudo tee /etc/apt/sources.list.d/playit-cloud.list > /dev/null
sudo apt update -qq
sudo apt install -y -qq playit
if [ $? -eq 0 ]; then
  success "Playit.gg installed!"
else
  warn "Playit installation failed. You can install it manually later."
fi

# =============================================
# Ask to start now
# =============================================
echo ""
echo "-- Would you like to start the server now? --"
echo "  [1] Yes"
echo "  [2] No"
echo ""

while true; do
  read -rp "Enter choice [1-2]: " StartServer
  case "$StartServer" in
    1)
      info "Starting server..."
      cd "$THIS_DIR"
      ./startserver
      break
      ;;
    2|"")
      info "You can start the server later by running ./startserver"
      break
      ;;
    *)
      error "Invalid choice. Please enter 1 or 2."
      ;;
  esac
done

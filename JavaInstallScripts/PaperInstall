#!/bin/bash
# Paper Installation Script
sudo apt update -qq
sudo apt install -y -qq curl jq > /dev/null

cd ..
mkdir -p server
cd server

echo -e "\n> Enter Minecraft version for server (or press Enter for latest): "
MINECRAFT_VERSION=latest
read MINECRAFT_VERSION

# -- EDIT HERE | DO NOT EDIT ABOVE -- #
BUILD_NUMBER=latest          # https://api.papermc.io/v2/projects/paper
PROJECT=paper                # PROJECT: https://api.papermc.io/v2/projects/
SERVER_JARFILE=server.jar    # LEAVE THIS PART ALONE
# -- EDIT HERE | DO NOT EDIT BELOW -- #

# Use the new v3 API
API_BASE="https://fill.papermc.io/v3/projects/${PROJECT}"

if [ -n "${DL_PATH}" ]; then
    echo -e "Using supplied download url: ${DL_PATH}"
    DOWNLOAD_URL=$(eval echo "$(echo "${DL_PATH}" | sed -e 's/{{/${/g' -e 's/}}/}/g')")
else
    # Automatically get the latest stable Minecraft version if not specified
    if [ -z "$MINECRAFT_VERSION" ] || [ "$MINECRAFT_VERSION" == "latest" ]; then
        MINECRAFT_VERSION=$(curl -s "${API_BASE}" | jq -r '
            .versions 
            | to_entries 
            | map(select(.key | startswith("1."))) 
            | sort_by(.key | split(".") | map(tonumber))
            | .[-1].value[0]
        ')
        echo -e "> Detected latest Paper version: ${MINECRAFT_VERSION}"
    fi

    # Check if the requested version exists by seeing if its versions endpoint returns an error
    VERSION_CHECK=$(curl -s "${API_BASE}/versions/${MINECRAFT_VERSION}")
    if echo "$VERSION_CHECK" | grep -q "error"; then
        echo -e "> ERROR: Version '${MINECRAFT_VERSION}' not found."
        exit 1
    fi

    echo -e "Version is valid. Using version ${MINECRAFT_VERSION}"

    if [ -z "$BUILD_NUMBER" ] || [ "$BUILD_NUMBER" == "latest" ]; then
        # The builds list is ordered from newest to oldest in v3, so [0] is latest
        BUILD_NUMBER=$(echo "$VERSION_CHECK" | jq -r '.builds[0]')
        echo -e "Using the latest ${PROJECT} build for version ${MINECRAFT_VERSION}: ${BUILD_NUMBER}"
    fi

    # Fetch build metadata to get the actual download URL (v3 uses object storage URLs)
    BUILD_META=$(curl -sSL -A "mcserverV3/1.0" "${API_BASE}/versions/${MINECRAFT_VERSION}/builds/${BUILD_NUMBER}")
    JAR_NAME=$(echo "$BUILD_META" | jq -r '.downloads[] | .name' | head -1)
    DOWNLOAD_URL=$(echo "$BUILD_META" | jq -r '.downloads[] | .url' | head -1)

    if [ -z "$DOWNLOAD_URL" ] || [ "$DOWNLOAD_URL" == "null" ]; then
        echo -e "> ERROR: Failed to parse download URL from Paper API."
        exit 1
    fi

    echo "Version being downloaded:"
    echo -e "  MC Version : ${MINECRAFT_VERSION}"
    echo -e "  Build      : ${BUILD_NUMBER}"
    echo -e "  JAR Name   : ${JAR_NAME}"
fi

echo -e "Downloading: ${DOWNLOAD_URL}"

if [ -f "${SERVER_JARFILE}" ]; then
    mv "${SERVER_JARFILE}" "${SERVER_JARFILE}.old"
fi

curl -sSL -A "mcserverV3/1.0" -o "${SERVER_JARFILE}" "${DOWNLOAD_URL}"

if [ ! -s "${SERVER_JARFILE}" ]; then
    echo -e "> ERROR: Download failed. File is empty or not found."
    exit 1
fi


echo -e "> Paper installation complete!"

#!/bin/bash
# Paper Installation Script
sudo apt update -qq
sudo apt install -y -qq curl jq > /dev/null

cd ..
mkdir -p server
cd server

echo -e "\n> Enter Minecraft version for server (or press Enter for latest): "
MINECRAFT_VERSION=latest
read MINECRAFT_VERSION

# -- EDIT HERE | DO NOT EDIT ABOVE -- #
BUILD_NUMBER=latest          # https://api.papermc.io/v2/projects/paper
PROJECT=paper                # PROJECT: https://api.papermc.io/v2/projects/
SERVER_JARFILE=server.jar    # LEAVE THIS PART ALONE
# -- EDIT HERE | DO NOT EDIT BELOW -- #

# Updated API base (old papermc.io/api/v2 returns 403)
API_BASE="https://api.papermc.io/v2/projects/${PROJECT}"

if [ -n "${DL_PATH}" ]; then
    echo -e "Using supplied download url: ${DL_PATH}"
    DOWNLOAD_URL=$(eval echo "$(echo "${DL_PATH}" | sed -e 's/{{/${/g' -e 's/}}/}/g')")
else
    VER_EXISTS=$(curl -s "${API_BASE}" | jq -r --arg VERSION "$MINECRAFT_VERSION" '.versions[] | select(. == $VERSION)' | head -1)
    LATEST_VERSION=$(curl -s "${API_BASE}" | jq -r '.versions[-1]')

    if [ -n "${VER_EXISTS}" ]; then
        echo -e "Version is valid. Using version ${MINECRAFT_VERSION}"
    else
        echo -e "Version '${MINECRAFT_VERSION}' not found. Using latest: ${LATEST_VERSION}"
        MINECRAFT_VERSION=${LATEST_VERSION}
    fi

    BUILD_EXISTS=$(curl -s "${API_BASE}/versions/${MINECRAFT_VERSION}" | jq -r --arg BUILD "${BUILD_NUMBER}" '.builds[] | tostring | contains($BUILD)' | grep true)
    LATEST_BUILD=$(curl -s "${API_BASE}/versions/${MINECRAFT_VERSION}" | jq -r '.builds[-1]')

    if [ "${BUILD_EXISTS}" == "true" ]; then
        echo -e "Build is valid for version ${MINECRAFT_VERSION}. Using build ${BUILD_NUMBER}"
    else
        echo -e "Using the latest ${PROJECT} build for version ${MINECRAFT_VERSION}: ${LATEST_BUILD}"
        BUILD_NUMBER=${LATEST_BUILD}
    fi

    JAR_NAME="${PROJECT}-${MINECRAFT_VERSION}-${BUILD_NUMBER}.jar"

    echo "Version being downloaded:"
    echo -e "  MC Version : ${MINECRAFT_VERSION}"
    echo -e "  Build      : ${BUILD_NUMBER}"
    echo -e "  JAR Name   : ${JAR_NAME}"

    DOWNLOAD_URL="${API_BASE}/versions/${MINECRAFT_VERSION}/builds/${BUILD_NUMBER}/downloads/${JAR_NAME}"
fi

echo -e "Downloading: ${DOWNLOAD_URL}"

if [ -f "${SERVER_JARFILE}" ]; then
    mv "${SERVER_JARFILE}" "${SERVER_JARFILE}.old"
fi

curl -o "${SERVER_JARFILE}" "${DOWNLOAD_URL}"


echo -e "> Paper installation complete!"

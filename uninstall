#!/bin/bash
export MAIN_DIR="$PWD"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()    { echo -e "${CYAN}> $1${NC}"; }
success() { echo -e "${GREEN}> $1${NC}"; }
warn()    { echo -e "${YELLOW}> WARNING: $1${NC}"; }
error()   { echo -e "${RED}> ERROR: $1${NC}"; }

info "Checking for server installation..."

if [ ! -d "$MAIN_DIR/server" ]; then
  error "No server installation found. Nothing to uninstall."
  exit 1
fi

echo ""
echo -e "${RED}=========================================="
echo "  Are you sure you want to uninstall?"
echo "  This will DELETE your server and all"
echo "  world data permanently!"
echo -e "==========================================${NC}"
echo ""
echo "  [1] Yes, delete everything"
echo "  [2] No, keep my server"
echo ""

while true; do
  read -rp "Enter choice [1-2]: " UninstallPick
  case "$UninstallPick" in
    1)
      warn "Stopping all running server processes..."
      # Kill only our specific screen sessions, not all
      for session in server playit afk; do
        if screen -ls | grep -q "$session"; then
          screen -S "$session" -X quit 2>/dev/null
        fi
      done
      sleep 1

      info "Removing server files..."
      rm -rf "$MAIN_DIR/server"
      rm -rf "$MAIN_DIR/bin"
      rm -f "$MAIN_DIR/.stop_requested"

      success "Uninstall complete!"
      echo ""
      echo "  To create a new server, run: ./install"
      echo "  Your backups (if any) are still in: backups/"
      echo ""
      break
      ;;
    2|"")
      info "Uninstall cancelled. Your server is safe."
      break
      ;;
    *)
      error "Please enter 1 or 2."
      ;;
  esac
done

#!/bin/bash
export MAIN_DIR=$PWD

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()    { echo -e "${CYAN}> $1${NC}"; }
success() { echo -e "${GREEN}> $1${NC}"; }
warn()    { echo -e "${YELLOW}> $1${NC}"; }
error()   { echo -e "${RED}> ERROR: $1${NC}"; }

info "Installing required dependencies..."
sudo apt install -qq screen wget unzip -y

mkdir -p server

echo ""
echo "-- Pick the following Server type: --"
echo "  [1] Create Vanilla Server"
echo "  [2] Create Nukkit Server (PowerNukkitX)"
echo "  [3] Create PocketmineMP Server"
echo ""

while true; do
    read -rp "Enter choice [1-3]: " choiceForServer
    case "$choiceForServer" in
        1|2|3) break ;;
        "") choiceForServer=1; break ;;
        *) error "Invalid choice. Please enter 1, 2, or 3." ;;
    esac
done

case "$choiceForServer" in
    1)
        info "Installing Vanilla Bedrock Server..."
        cd BedrockInstallScripts && chmod +x VanillaInstall && ./VanillaInstall
        cd "$MAIN_DIR"
        ;;
    2)
        info "Installing Nukkit Server..."
        cd BedrockInstallScripts && chmod +x NukkitInstall && ./NukkitInstall
        cd "$MAIN_DIR"
        ;;
    3)
        info "Installing PocketmineMP Server..."
        cd BedrockInstallScripts && chmod +x PocketmineInstall && ./PocketmineInstall
        cd "$MAIN_DIR"
        ;;
esac

# Install Playit.gg via official APT PPA (old direct binary URL is dead)
info "Installing Playit.gg tunnel..."
curl -SsL https://playit-cloud.github.io/ppa/key.gpg | gpg --dearmor | sudo tee /etc/apt/trusted.gpg.d/playit.gpg > /dev/null
echo "deb [signed-by=/etc/apt/trusted.gpg.d/playit.gpg] https://playit-cloud.github.io/ppa/data ./" | sudo tee /etc/apt/sources.list.d/playit-cloud.list
sudo apt update -qq
sudo apt install -y -qq playit
if [ $? -eq 0 ]; then
    success "Playit.gg installed!"
else
    warn "Playit installation failed. Try installing it manually: https://playit.gg/download/linux"
fi

echo ""
echo "-- Do you want to start the server now? --"
echo "  [1] Yes"
echo "  [2] No"
echo ""

while true; do
    read -rp "Enter choice [1-2]: " StartServer
    case "$StartServer" in
        1)
            info "Starting server..."
            cd "$MAIN_DIR" && ./startserver
            break
            ;;
        2|"")
            info "You can start the server later by running ./startserver"
            break
            ;;
        *) error "Please enter 1 or 2." ;;
    esac
done
